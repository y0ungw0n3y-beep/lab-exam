      </section>

      <section id="contact" class="card contact-card">
        <h3>Let's Connect</h3>
        <form class="contact-form" action="#" method="POST">
          <label for="fullName" class="sr-only">Full Name</label>
          <input type="text" id="fullName" placeholder="Full Name" required />

          <label for="email" class="sr-only">Email Address</label>
          <input type="email" id="email" placeholder="Email Address" required />

          <label for="subject" class="sr-only">Subject</label>
          <input type="text" id="subject" placeholder="Subject" required />

          <label for="message" class="sr-only">Message</label>
          <textarea
            id="message"
            placeholder="Message"
            rows="3"
            required
          ></textarea>

          <div class="form-buttons">
            <button type="submit" class="btn-submit">Send Message</button>
            <button type="submit" class="btn-reset">Reset</button>
          </div>
        </form>
        <br /><br />
        <div class="contact-infos">
          <div class="info-item">
            <i
              class="fa-regular fa-envelope"
              style="color: rgb(69, 178, 255)"
            ></i>
            <p><strong>jhondavidbrillantes@gmail.com</strong></p>
          </div>

          <div class="info-item">
            <i class="fa-solid fa-phone" style="color: rgb(99, 230, 190)"></i>
            <p><strong>(+63) 906 096 9421</strong></p>
          </div>

          <div class="info-item">
            <i
              class="fa-solid fa-location-dot"
              style="color: rgb(255, 212, 59)"
            ></i>
            <p><strong>Mamatid, Cabuyao, Laguna</strong></p>
          </div>

          <div class="info-item">
            <i
              class="fa-solid fa-business-time"
              style="color: rgb(208, 102, 102)"
            ></i>
            <p><strong>Monday - Saturday 8AM - 8PM</strong></p>
          </div>
