          <div class="mini-card">
            <i class="fa-brands fa-html5" style="color: rgb(255, 132, 9)"></i>
            <span>HTML</span>
            <span class="percentage">30%</span>
          </div>
          <div class="mini-card">
            <i
              class="fa-brands fa-css3-alt"
              style="color: rgb(116, 192, 252)"
            ></i>
            <span>CSS</span>
            <span class="percentage">40%</span>
          </div>
          <div class="mini-card">
            <i
              class="fa-brands fa-square-js"
              style="color: rgb(255, 212, 59)"
            ></i>
            <span>JavaScript</span>
            <span class="percentage">20%</span>
          </div>
          <div class="mini-card">
            <i class="fa-solid fa-bug" style="color: rgb(10, 0, 0)"></i>
            <span>Problem Solving</span>
            <span class="percentage">70%</span>
          </div>
          <div class="mini-card">
            <i
              class="fa-solid fa-handshake-angle"
              style="color: rgb(0, 59, 255)"
            ></i>
            <span>Teamwork</span>
            <span class="percentage">90%</span>
          </div>
          <div class="mini-card">
            <i
              class="fa-solid fa-comment-dots"
              style="color: rgb(95, 187, 129)"
            ></i>
            <span>Communication</span>
            <span class="percentage">90%</span>
          </div>
        </div>
      </section>

      <section id="portfolio" class="card portfolio-card">
        <h3>Project Gallery</h3>
        <div class="gallery-grid">
          <div class="gallery-item">
            <img src="images/pr1.jpg" alt="P1" />
            <div class="caption">Project 1</div>
          </div>
          <div class="gallery-item">
            <img src="images/pr2.jpg" alt="P2" />
            <div class="caption">Project 2</div>
          </div>
          <div class="gallery-item">
